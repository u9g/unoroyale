{
  "name": "unoroyale",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "lint:css": "stylelint \"src/**/*.css\"",
    "lint": "eslint src/ && stylelint \"src/**/*.css\"",
    "cap:sync": "npm run build && npx cap sync ios",
    "cap:sync:android": "npm run build && npx cap sync android",
    "cap:open": "npx cap open ios",
    "screenshots": "node scripts/take-screenshots.mjs",
    "deploy": "sh scripts/deploy-ios.sh"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.0",
    "@capacitor/core": "^8.3.0",
    "@capacitor/ios": "^8.3.0",
    "vue": "^3.5.30"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.0",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.1.0",
    "eslint-plugin-vue": "^10.8.0",
    "playwright": "^1.58.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tslib": "^2.8.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.57.2",
    "vite": "^8.0.1",
    "vitest": "^4.1.2",
    "vue-tsc": "^3.2.5"
  }
}
