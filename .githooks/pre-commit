#!/bin/sh

# Check if engine files are being changed without corresponding test changes
engine_changes=$(git diff --cached --name-only -- src/engine/ | grep -v '\.test\.ts$')
test_changes=$(git diff --cached --name-only -- src/engine/ | grep '\.test\.ts$')

if [ -n "$engine_changes" ] && [ -z "$test_changes" ]; then
  echo "ERROR: Engine files were modified but no engine tests were added or updated."
  echo ""
  echo "Changed engine files:"
  echo "$engine_changes" | sed 's/^/  /'
  echo ""
  echo "Please add or update tests in src/engine/*.test.ts for the new behavior."
  echo "To bypass this check (not recommended): git commit --no-verify"
  exit 1
fi

# Run all checks in parallel
tmpdir=$(mktemp -d)

(npx eslint src/ >"$tmpdir/eslint.log" 2>&1; echo $? >"$tmpdir/eslint.exit") &
(npx stylelint "src/**/*.css" >"$tmpdir/stylelint.log" 2>&1; echo $? >"$tmpdir/stylelint.exit") &
(npx vitest run >"$tmpdir/vitest.log" 2>&1; echo $? >"$tmpdir/vitest.exit") &
(node scripts/take-screenshots.mjs >"$tmpdir/screenshots.log" 2>&1; echo $? >"$tmpdir/screenshots.exit") &

wait

failed=0

if [ "$(cat "$tmpdir/eslint.exit")" != "0" ]; then
  echo "ESLint failed!"
  cat "$tmpdir/eslint.log"
  failed=1
else
  echo "ESLint passed."
fi

if [ "$(cat "$tmpdir/stylelint.exit")" != "0" ]; then
  echo "CSS lint failed!"
  cat "$tmpdir/stylelint.log"
  failed=1
else
  echo "CSS lint passed."
fi

if [ "$(cat "$tmpdir/vitest.exit")" != "0" ]; then
  echo "Engine tests failed!"
  cat "$tmpdir/vitest.log"
  failed=1
else
  echo "All engine tests passed."
fi

if [ "$(cat "$tmpdir/screenshots.exit")" != "0" ]; then
  echo "Screenshot generation failed!"
  cat "$tmpdir/screenshots.log"
  failed=1
else
  git add screenshots/
  echo "Screenshots generated and staged."
fi

rm -rf "$tmpdir"

if [ "$failed" != "0" ]; then
  echo "Pre-commit checks failed! Commit aborted."
  exit 1
fi
