#!/bin/sh

# Check if engine files are being changed without corresponding test changes
engine_changes=$(git diff --cached --name-only -- src/engine/ | grep -v '\.test\.ts$')
test_changes=$(git diff --cached --name-only -- src/engine/ | grep '\.test\.ts$')

if [ -n "$engine_changes" ] && [ -z "$test_changes" ]; then
  echo "ERROR: Engine files were modified but no engine tests were added or updated."
  echo ""
  echo "Changed engine files:"
  echo "$engine_changes" | sed 's/^/  /'
  echo ""
  echo "Please add or update tests in src/engine/*.test.ts for the new behavior."
  echo "To bypass this check (not recommended): git commit --no-verify"
  exit 1
fi

# Lint Vue + TypeScript
echo "Linting Vue + TypeScript..."
npx eslint src/ 2>&1
if [ $? -ne 0 ]; then
  echo "ESLint failed! Commit aborted."
  exit 1
fi
echo "ESLint passed."

# Lint CSS
echo "Linting CSS..."
npx stylelint "src/**/*.css" 2>&1
if [ $? -ne 0 ]; then
  echo "CSS lint failed! Commit aborted."
  exit 1
fi
echo "CSS lint passed."

# Run engine tests
echo "Running UNO engine tests..."
npx vitest run 2>&1
exit_code=$?
if [ $exit_code -ne 0 ]; then
  echo "Engine tests failed! Commit aborted."
  exit 1
fi
echo "All engine tests passed."
